			name: 'DJ Hoodie',
			rating: 5,
			price: '$79.99'
		}
	]

section.filters
	each filter in filters
		button.filter(data-filter=filter)= filter

section.products
	- let i = 0;
	while i++ < 6
		each product in products
			a.product(href="#", data-filter=generateFilterList())
				.product__inner
					.product__image
						img.product__image-inner(src=product.image)
					h4.product__name= product.name
					data.product__rating(value=product.rating)
						span
						span
						span
						span
						span
					p.product__price= product.price

section.other
	h2 Some Other Content
	p This is another section on the page. It is here to demonstrate how the hight of the products grid smoothly animates as products are filtered on and off the screen
