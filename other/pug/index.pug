-
	const filters = ["Best Sellers", "New Arrivals", "Hot Sales"]
	const generateFilterList = (_list = []) => {
		const filter = filters[Math.floor(Math.random() * filters.length)];
		if (!_list.includes(filter)) _list.push(filter)
		if (_list.length >= 2) return _list.join(',');
		return generateFilterList(_list);
	};
	const products = [
		{
			image:'https://images.unsplash.com/photo-1560769629-975ec94e6a86?ixlib=rb-1.2.1&ixid=MnwxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8&auto=format&fit=crop&w=764&q=80',
			name: 'Some Cool Shoes',
			rating: 5,
			price: '$65.99'
		},
		{
			image:'https://images.unsplash.com/photo-1483103068651-8ce44652c331?ixlib=rb-1.2.1&ixid=MnwxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8',
			name: 'Super Dope Hat',
			rating: 3,
			price: '$38.99'
		},
		{
			image:'https://images.unsplash.com/photo-1585751092218-cea84c1ecf01?ixlib=rb-1.2.1&ixid=MnwxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8&auto=format',
			name: 'Radical Tie-dye Shirt',
			rating: 4,
			price: '$65.99'
		},
		{
			image:'https://images.unsplash.com/photo-1632226390535-2f02c1a93541?ixlib=rb-1.2.1&ixid=MnwxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8&auto=format&fit=crop&w=764&q=80',
			name: 'Very Suave Vest',
